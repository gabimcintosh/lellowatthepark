{
  "path": "cz-conventional-changelog",
  "types": [
    {
      "value": "feat",
      "name": "feat:     :sparkles: A new feature",
      "description": "A new feature"
    },
    {
      "value": "fix",
      "name": "fix:      :bug: A bug fix",
      "description": "A bug fix"
    },
    {
      "value": "docs",
      "name": "docs:     :docs: Documentation only changes",
      "description": "Documentation only changes"
    },
    {
      "value": "style",
      "name": "style:    :art: Changes that do not affect the meaning of the code",
      "description": "Changes that do not affect the meaning of the code (white-space, formatting, missing semi-colons, etc)"
    },
    {
      "value": "refactor",
      "name": "refactor: :hammer: A code change that neither fixes a bug nor adds a feature",
      "description": "A code change that neither fixes a bug nor adds a feature"
    },
    {
      "value": "perf",
      "name": "perf:     :zap: A code change that improves performance",
      "description": "A code change that improves performance"
    },
    {
      "value": "test",
      "name": "test:     :white_check_mark: Adding missing tests or correcting existing tests",
      "description": "Adding missing tests or correcting existing tests"
    },
    {
      "value": "build",
      "name": "build:    :construction: Changes that affect the build system or external dependencies",
      "description": "Changes that affect the build system or external dependencies (example scopes: gulp, broccoli, npm)"
    },
    {
      "value": "ci",
      "name": "ci:       :green_heart: Changes to our CI configuration files and scripts",
      "description": "Changes to our CI configuration files and scripts (example scopes: Travis, Circle, BrowserStack, SauceLabs)"
    },
    {
      "value": "chore",
      "name": "chore:    :wrench: Maintenance tasks",
      "description": "Maintenance tasks (updating dependencies, configuring tools, etc)"
    },
    {
      "value": "revert",
      "name": "revert:   :rewind: Revert previous commit",
      "description": "Revert previous commit"
    }
  ],
  "scopes": [],
  "allowCustomScopes": true,
  "allowBreakingChanges": ["feat", "fix", "perf"],
  "skipQuestions": ["body", "footer"],
  "upperCaseSubject": false,
  "subjectSeparator": " ",
  "gitmoji": true
}
